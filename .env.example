# Copy this file to .env and fill in what you need.
# Every value below is optional - the app degrades gracefully (with a
# clear error or a no-op) when a given integration isn't configured.
# See README.md > "Environment Variables" for full details.

# --- Server ---
# PORT is set automatically by most hosting platforms (e.g. Railway).
# Leave unset locally; the dev server defaults to 3000.
# PORT=3000
NODE_ENV=development

# --- Database (optional) ---
# MySQL connection string. Without this, forms still submit but
# nothing is persisted (no leads, uploads, or chat history saved).
# DATABASE_URL=mysql://user:password@host:3306/daqs

# --- LLM gateway (chatbot, /live-demo) ---
# WARNING: this URL/key pair is ALSO used by server/storage.ts for
# admin file uploads, which expects a different (Manus-specific) API
# shape. Repointing this at another LLM provider will break uploads.
# See README.md for the full explanation.
#
# Example using Google Gemini's OpenAI-compatible endpoint:
# BUILT_IN_FORGE_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# BUILT_IN_FORGE_API_KEY=your-gemini-api-key

# --- Admin auth ---
# OAUTH_SERVER_URL=
# JWT_SECRET=
# OWNER_OPEN_ID=
